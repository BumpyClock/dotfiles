{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Projects/dotfiles/.claude/hooks/block-destructive-commands.sh\"",
            "timeout": 5,
            "statusMessage": "Checking destructive command policy"
          }
        ]
      }
    ]
  }
}
