{
  "lastChangelogVersion": "0.80.10",
  "defaultProvider": "xai",
  "defaultModel": "grok-4.5",
  "defaultThinkingLevel": "high",
  "subagents": {
    "agentOverrides": {
      "context-builder": {
        "model": "openai-codex/gpt-5.3-codex-spark"
      },
      "delegate": {
        "model": "openai-codex/claude-opus-4.6",
        "disabled": true
      },
      "oracle": {
        "model": "github-copilot/gpt-5.5",
        "thinking": "xhigh",
        "context": "fork"
      },
      "planner": {
        "model": "github-copilot/gpt-5.5",
        "thinking": "xhigh",
        "disabled": true
      },
      "researcher": {
        "model": "github-copilot/claude-sonnet-4.6",
        "disabled": true
      },
      "reviewer": {
        "model": "github-copilot/gpt-5.5",
        "disabled": true
      },
      "scout": {
        "model": "zai/glm-5.2",
        "thinking": "medium"
      },
      "worker": {
        "model": "github-copilot/claude-opus-4.8",
        "disabled": true
      },
      "technical-writer": {
        "model": "zai/glm-5.2"
      }
    }
  },
  "packages": [
    "npm:pi-subagents",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:pi-lens",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:pi-markdown-preview",
    "npm:@juicesharp/rpiv-advisor",
    "npm:@juicesharp/rpiv-btw",
    "npm:@bumpyclock/pi-statusbar",
    "npm:@ifi/oh-pi-themes",
    "npm:pi-teams",
    "npm:@bumpyclock/pi-tasque",
    "npm:@narumitw/pi-goal",
    "npm:@quintinshaw/pi-dynamic-workflows"
  ],
  "terminal": {
    "showTerminalProgress": true
  },
  "quietStartup": true,
  "theme": "catppuccin-macchiato/catppuccin-mocha",
  "hideThinkingBlock": false,
  "statusbar": {
    "preset": "default-no-cost",
    "presets": {
      "default-no-cost": {
        "extends": "default",
        "leftSegments": [
          "model",
          "thinking",
          "shell_mode",
          "path",
          "git",
          "context_pct",
          "cache_read"
        ]
      }
    },
    "fixedEditor": true,
    "mouseScroll": true,
    "customItems": [
      {
        "id": "context_gauge"
      }
    ],
    "vibe": {
      "enabled": true,
      "source": "packs",
      "disabledPacks": [],
      "safeMode": true,
      "animation": "shimmer",
      "generated": {
        "model": "openai-codex/gpt-5.3-codex-spark",
        "prompt": "Generate a 2-4 word \"{theme}\" themed loading message ending in \"...\".\n\nTask: {task}\n\nBe creative, funny, sarcastic, and unexpected. Avoid obvious/clichéd phrases for this theme.\nRelevant catchphrases, quotes, and themes should be incorporated into the message.\nThe message should hint at the task using theme vocabulary. modify catchphrase, quotes, and themes as needed.\n{exclude}\nOutput only the message, nothing else.",
        "refreshInterval": 30
      }
    }
  },
  "extensionSettings": {
    "personalitySwitcher": {
      "personality": "caveman",
      "styles": []
    },
    "dynamicTitle": {
      "model": "zai/glm-5.2",
      "updateAfterTurns": 30
    }
  }
}