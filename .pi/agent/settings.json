{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "subagents": {
    "agentOverrides": {
      "context-builder": {
        "model": "openai-codex/gpt-5.3-codex-spark"
      },
      "delegate": {
        "model": "openai-codex/claude-opus-4.6",
        "disabled": true
      },
      "oracle": {
        "model": "github-copilot/gpt-5.5",
        "context": "fresh"
      },
      "planner": {
        "model": "github-copilot/gpt-5.5",
        "thinking": "xhigh",
        "disabled": true
      },
      "researcher": {
        "model": "github-copilot/claude-sonnet-4.6",
        "disabled": true
      },
      "reviewer": {
        "model": "github-copilot/gpt-5.5",
        "disabled": true
      },
      "scout": {
        "model": "openai-codex/gpt-5.3-codex-spark",
        "thinking": "medium"
      },
      "worker": {
        "model": "github-copilot/claude-opus-4.6",
        "disabled": true
      },
      "technical-writer": {
        "model": "zai/glm-5.1"
      }
    }
  },
  "packages": [
    "npm:pi-subagents",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:pi-lens",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:pi-markdown-preview",
    "npm:@juicesharp/rpiv-advisor",
    "npm:@juicesharp/rpiv-btw",
    "npm:pi-codex-goal",
    "../../Projects/pi-statusbar",
    "npm:@ifi/oh-pi-themes",
    "npm:pi-teams",
    "npm:pi-intercom",
    "npm:@bumpyclock/pi-tasque"
  ],
  "terminal": {
    "showTerminalProgress": true
  },
  "quietStartup": true,
  "theme": "catppuccin-mocha",
  "hideThinkingBlock": false,
  "statusbar": {
    "preset": "default-no-cost",
    "presets": {
      "default-no-cost": {
        "extends": "default",
        "leftSegments": [
          "model",
          "thinking",
          "shell_mode",
          "path",
          "git",
          "context_pct",
          "cache_read"
        ]
      }
    },
    "fixedEditor": true,
    "mouseScroll": false,
    "customItems": [
      {
        "id": "context_gauge"
      }
    ]
  },
  "extensionSettings": {
    "personalitySwitcher": {
      "personality": "caveman",
      "styles": [
        "explanatory"
      ]
    },
    "dynamicTitle": {
      "model": "openai-codex/gpt-5.3-codex-spark",
      "updateAfterTurns": 10
    }
  }
}
